# --- Backend SmartCart: variables de entorno ---
# Copiar a .env y completar. El backend valida esto al arrancar (Zod)
# y falla rápido si falta algo obligatorio.

# Ambiente: dev | staging | production
NODE_ENV=dev

# Puerto HTTP del backend
PUERTO=3000

# Conexión a PostgreSQL (coincide con infra/docker-compose.yml)
DATABASE_URL=postgresql://smartcart:smartcart_dev@localhost:5432/smartcart_dev

# Secreto para firmar JWT (obligatorio; usar uno fuerte fuera de dev)
JWT_SECRETO=cambiar-este-secreto-en-staging-y-produccion

# Sentry (opcional en dev; si está vacío no se inicializa)
SENTRY_DSN=

# Mercado Pago sandbox (Sprint 3) — TODO: integración real
MERCADOPAGO_ACCESS_TOKEN=
