# --- App móvil SmartCart: variables de entorno (Expo) ---
# Las variables EXPO_PUBLIC_* quedan embebidas en el bundle: nunca poner secretos acá.

# URL del backend. En dispositivo físico usar la IP de la máquina de desarrollo
# (ej: http://192.168.0.10:3000), no localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Sentry (opcional en dev; se inicializa solo si está presente) — Sprint 2
EXPO_PUBLIC_SENTRY_DSN=
